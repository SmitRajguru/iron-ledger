# --- build / dependency artifacts (rebuilt locally; never committed) ---
node_modules/
dist/
__pycache__/
.venv/
*.pyc
# vite writes a temp config file that bakes an absolute local path; never commit it.
*.timestamp-*.mjs

# uv.lock is intentionally NOT committed: development happens on a network whose
# uv.lock pins a PRIVATE package mirror. The deploy box re-resolves from public
# PyPI (pyproject deps are loose). See README "Checks" / scripts/check-public-deps.sh.
server/uv.lock

# --- secrets + runtime state (machine-specific) ---
# Server secrets (generated by setup.sh). Never commit.
server/.env
# Generated systemd unit (machine-specific paths), if ever produced.
deploy/*.generated.service

# Runtime data: keep the directory, ignore its contents.
/data/*
!/data/.gitkeep
# Local backups.
/backups/

# --- misc ---
.DS_Store
*.log
