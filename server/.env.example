# Iron Ledger server environment. Copy to server/.env (gitignored) and fill in.
# setup.sh / run.sh generate server/.env automatically with a random WT_SECRET if absent.

# Secret used to sign the session cookie. MUST be long and random.
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
WT_SECRET=replace-with-a-long-random-string

# Shared invite code required for signup. Hand this to trusted users only.
# Signup is DISABLED (503) while this still starts with "change-me".
WT_INVITE_CODE=change-me

# OPTIONAL — comma-separated Host allow-list (defense vs Host-header spoofing).
# Set to your public hostname(s) once deployed; localhost/127.0.0.1 are always
# allowed. Unset = accept any Host (fine since uvicorn binds 127.0.0.1).
# WT_ALLOWED_HOSTS=ironledger.example.com

# OPTIONAL — override the data directory (default: <repo>/data).
# WT_DATA_DIR=/srv/iron-ledger/data

# OPTIONAL — the single prod listen host/port (the server serves API + client on
# ONE origin). Read by run.sh + the systemd unit (which launch uvicorn with
# --host ${WT_HOST} --port ${WT_PORT}). NOTE: a hand-typed `uvicorn` ignores these
# unless you pass the flags yourself. Use 127.0.0.1 for tunnel-only; use 0.0.0.0 to
# reach the box on its LAN IP (e.g. http://10.0.0.15:8000).
# WT_HOST=127.0.0.1
# WT_PORT=8000

# OPTIONAL — session-cookie Secure flag. auto (default) = Secure off-localhost
# (HTTPS via the tunnel). Set "false" when serving over PLAIN HTTP on a LAN IP, or
# the browser drops the cookie over http:// and login fails. (Plain-HTTP LAN access
# also disables PWA install + the offline service worker — those need HTTPS/localhost.)
# WT_COOKIE_SECURE=auto

# OPTIONAL (DEV ONLY) — CORS origin for the Vite dev client if you change its port.
# Prod is same-origin (no CORS). e.g. if you run `WT_CLIENT_PORT=5174 npm run dev`:
# WT_DEV_ORIGIN=http://localhost:5174
